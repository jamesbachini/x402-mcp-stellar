# Required: Stellar secret key for the paying wallet (starts with S...)
STELLAR_SECRET_KEY=

# Optional: network selector. Defaults to stellar:testnet
# Use stellar:pubnet for mainnet
STELLAR_NETWORK=stellar:testnet

# Optional: required when STELLAR_NETWORK=stellar:pubnet
# Example: https://mainnet.sorobanrpc.com
STELLAR_RPC_URL=

# Optional: MCP server metadata
MCP_SERVER_NAME=x402-stellar-resource-client
MCP_SERVER_VERSION=1.0.0
