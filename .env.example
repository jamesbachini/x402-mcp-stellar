# Required: Stellar secret key for the paying wallet (starts with S...)
# Setup at https://lab.stellar.org/account/create
STELLAR_SECRET_KEY=

# Use Stellar mainnet for OpenZeppelin facilitator channels
STELLAR_NETWORK=stellar:testnet

# Required on mainnet: Soroban RPC URL
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# OpenZeppelin facilitator configuration (testnet)
# API key here: https://channels.openzeppelin.com/testnet/gen
X402_FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
X402_FACILITATOR_API_KEY=

# Optional: MCP server metadata
MCP_SERVER_NAME=x402-stellar
MCP_SERVER_VERSION=1.0.0
